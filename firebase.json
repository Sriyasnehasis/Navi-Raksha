{
  "hosting": {
    "source": "web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/ambulances/**",
        "run": { "serviceId": "navi-raksha-backend", "region": "us-central1" }
      },
      {
        "source": "/incidents/**",
        "run": { "serviceId": "navi-raksha-backend", "region": "us-central1" }
      },
      {
        "source": "/hospitals/**",
        "run": { "serviceId": "navi-raksha-backend", "region": "us-central1" }
      },
      {
        "source": "/dispatch",
        "run": { "serviceId": "navi-raksha-backend", "region": "us-central1" }
      },
      {
        "source": "/health",
        "run": { "serviceId": "navi-raksha-backend", "region": "us-central1" }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "frameworksBackend": {
      "region": "us-central1"
    }
  }
}
