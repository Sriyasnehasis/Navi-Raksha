# NaviRaksha Backend API - Environment Configuration
# Copy this file to .env and update values as needed

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_APP=modules/backend/app.py

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=INFO

# Model Paths (relative to project root)
RF_MODEL_PATH=models/trained/rf_model.pkl
RF_SCALER_PATH=models/trained/rf_features.pkl

# Database (when needed)
# DATABASE_URL=

# CORS Settings
CORS_ORIGINS=*

# Feature Configuration (for ETA prediction)
MIN_ETA_MINUTES=3
MAX_ETA_MINUTES=20

# Ambulance Configuration
AMBULANCE_TYPES={1: 'ALS', 2: 'BLS', 3: 'Advanced'}
ALS_SPEED_KMPH=45
BLS_SPEED_KMPH=40
ADVANCED_SPEED_KMPH=50

# Hospital Configuration
DEFAULT_BEDS_EMERGENCY=10
DEFAULT_BEDS_ICU=5

# Feature Names (for debugging)
FEATURE_NAMES=distance,hour,is_monsoon,ambulance_type,violations_zone
